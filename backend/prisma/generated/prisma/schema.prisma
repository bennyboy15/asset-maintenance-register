// This is your updated Prisma schema file for PostgreSQL

generator client {
  provider = "prisma-client-js" // Changed from "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql" // Changed from "postgres"
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}
